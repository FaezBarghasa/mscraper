<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules xmlns:android="http://schemas.android.com/apk/res/android">
    <cloud-backup>
        <!-- Include User Library Database -->
        <include domain="database" path="cyber_music_database" />
        <include domain="database" path="cyber_music_database-shm" />
        <include domain="database" path="cyber_music_database-wal" />

        <!-- Include Application Settings -->
        <include domain="sharedpref" path="crysta_settings_v1.xml" />

        <!-- Exclude Cache -->
        <exclude domain="cache" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Transfer everything except cache for local device moves -->
        <include domain="root" path="." />
        <exclude domain="cache" path="." />
    </device-transfer>
</data-extraction-rules>
